# simulador de caixa eletrônico

saldo = 500

while saldo > 0:
    saque = float(input("Informe o valor do saque: "))

    if saque == 0:
        break

    if saque > saldo:
        print("Saldo insuficiente! Saque indisponível.")
    else:
        saldo -= saque
        print(f"Saque efetuado! Novo saldo R$ {saldo:.2f}")

